default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false
    )

    # Import certificate
    import_certificate(
      certificate_path: ENV["CERT_PATH"],
      certificate_password: ENV["CERT_PASSWORD"],
      keychain_name: ENV["KEYCHAIN_NAME"] || "login.keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || ""
    )

    # Install provisioning profile
    install_provisioning_profile(path: ENV["PROFILE_PATH"])

    # Get the UUID of installed profile
    profile_uuid = lane_context[SharedValues::SIGH_UDID] || ENV["PROFILE_UUID"]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: ENV["TEAM_ID"],
      bundle_identifier: "com.msouwout.app",
      profile_name: "MsouWout AppStore",
      code_sign_identity: "iPhone Distribution"
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      clean: true,
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.msouwout.app" => "MsouWout AppStore"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build and upload for App Store release"
  lane :release do
    beta

    upload_to_app_store(
      api_key: app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_content: ENV["ASC_KEY_CONTENT"],
        is_key_content_base64: true,
        in_house: false
      ),
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      submit_for_review: false,
      automatic_release: false
    )
  end
end
